<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Multi-company record rule: users only see employee lines
        belonging to their own company (or companies they have access to).
    -->
    <record id="rule_project_employee_line_company" model="ir.rule">
        <field name="name">Project Employee Line: Company</field>
        <field name="model_id" ref="model_project_employee_line"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
