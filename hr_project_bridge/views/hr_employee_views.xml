<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         EMPLOYEE FORM — add Projects smart button
    ════════════════════════════════════════════════════════════════════════ -->
    <record id="view_employee_form_inherit_project_bridge" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.project.bridge</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_employee_projects"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-folder-open">
                    <field name="project_count"
                           widget="statinfo"
                           string="Projects"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
